{% set optionsOrderState = column.options.ModuleClass.getTrackingState('',record['id_order']) %}
{% set listOrderId = column.options.ModuleClass.getTrackingState(record['id_order']) %}
{% set orderState = column.options.ModuleClass.getTrackingState(record['wk_id_state']) %}

<select name="order_state" class="order_state form-control" data-id-order="{{listOrderId}}">
    {% for typeKey,typeVal in optionsOrderState %}
        {% if typeVal %}
            <option value="{{typeKey}}" {% if orderState == typeKey %}selected="selected" {% endif %}>
                {{typeVal}}
            </option>
        {% endif %}
    {% endfor %}
</select>