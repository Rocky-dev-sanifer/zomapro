{*
* Footer du formulaire d'ajout : boutons de navigation
*}
<div class="re-form-footer">
  <button
    type="button"
    id="re-prev-btn"
    class="re-btn-ghost"
  >
    <i
      data-lucide="move-left"
      width="20"
      height="20"
    ></i> Précédent
  </button>
  <button
    type="button"
    id="re-next-btn"
    class="re-btn-primary"
  >
    Étape suivante <i
      data-lucide="move-right"
      width="20"
      height="20"
    ></i>
  </button>
  <button
    type="button"
    id="re-finish-btn"
    class="re-btn-primary"
    style="display:none;"
  >
    <i
      data-lucide="check"
      width="20"
      height="20"
    ></i> Publier l'annonce
  </button>
</div>

<p class="re-footnote">
  Tous les champs marqués d'un <span style="color:#c0392b;">*</span> sont obligatoires
  <br>
  <small>Les informations sont sécurisées et confidentielles</small>
</p>